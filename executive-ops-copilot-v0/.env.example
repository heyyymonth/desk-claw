# Frontend
WEB_BACKEND_URL=http://localhost:8000

# Web Backend
AI_BACKEND_URL=http://localhost:9000

# AI Backend general
AI_BACKEND_PORT=9000
DEFAULT_AI_PROVIDER=ollama
FALLBACK_AI_PROVIDER=openai
AI_REQUEST_TIMEOUT_SECONDS=120

# Ollama
OLLAMA_API_KEY=replace_me
OLLAMA_BASE_URL=https://ollama.com/api
OLLAMA_DEFAULT_MODEL=gemma4:31b-cloud

# OpenAI
OPENAI_API_KEY=replace_me
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_DEFAULT_MODEL=gpt-5.5

# Anthropic
ANTHROPIC_API_KEY=replace_me
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_DEFAULT_MODEL=claude-opus-4-7
ANTHROPIC_VERSION=2023-06-01

# Gemini
GEMINI_API_KEY=replace_me
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_API_VERSION=v1beta
GEMINI_DEFAULT_MODEL=gemini-3.1-flash-lite
GEMINI_OPENAI_COMPAT_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
GEMINI_USE_OPENAI_COMPAT=false
