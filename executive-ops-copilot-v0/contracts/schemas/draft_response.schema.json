{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.executive-ops-copilot/contracts/draft_response.schema.json",
  "title": "DraftResponse",
  "description": "Editable draft response returned by the backend draft endpoint.",
  "$ref": "#/$defs/DraftResponse",
  "$defs": {
    "ModelStatus": { "type": "string", "enum": ["used", "unavailable", "invalid_output", "not_configured"] },
    "DraftType": { "type": "string", "enum": ["accept", "decline", "clarify", "defer"] },
    "DraftResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["subject", "body", "tone", "draft_type", "model_status"],
      "properties": {
        "subject": { "type": "string", "minLength": 1 },
        "body": { "type": "string", "minLength": 1 },
        "tone": { "type": "string", "enum": ["concise", "warm", "firm"] },
        "draft_type": { "$ref": "#/$defs/DraftType" },
        "model_status": { "$ref": "#/$defs/ModelStatus" }
      }
    }
  }
}
