{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.executive-ops-copilot/contracts/meeting_request.schema.json",
  "title": "ParsedMeetingRequest",
  "description": "Parsed meeting request returned by the backend parser endpoint.",
  "$ref": "#/$defs/ParsedMeetingRequest",
  "$defs": {
    "Priority": { "type": "string", "enum": ["low", "normal", "high", "urgent"] },
    "MeetingType": {
      "type": "string",
      "enum": ["intro", "internal", "customer", "investor", "candidate", "vendor", "board", "partner", "legal_hr", "personal", "other"]
    },
    "Sensitivity": { "type": "string", "enum": ["low", "medium", "high"] },
    "TimeWindow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start", "end"],
      "properties": {
        "start": { "type": "string", "format": "date-time" },
        "end": { "type": "string", "format": "date-time" }
      }
    },
    "MeetingIntent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "requester",
        "duration_minutes",
        "priority",
        "meeting_type",
        "attendees",
        "preferred_windows",
        "constraints",
        "missing_fields",
        "sensitivity",
        "async_candidate",
        "escalation_required"
      ],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "requester": { "type": "string", "minLength": 1 },
        "duration_minutes": { "type": "integer", "minimum": 15, "maximum": 240 },
        "priority": { "$ref": "#/$defs/Priority" },
        "meeting_type": { "$ref": "#/$defs/MeetingType" },
        "attendees": { "type": "array", "items": { "type": "string" } },
        "preferred_windows": { "type": "array", "items": { "$ref": "#/$defs/TimeWindow" } },
        "constraints": { "type": "array", "items": { "type": "string" } },
        "missing_fields": { "type": "array", "items": { "type": "string" } },
        "sensitivity": { "$ref": "#/$defs/Sensitivity" },
        "async_candidate": { "type": "boolean" },
        "escalation_required": { "type": "boolean" }
      }
    },
    "ParsedMeetingRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["raw_text", "intent"],
      "properties": {
        "raw_text": { "type": "string", "minLength": 1, "maxLength": 12000 },
        "intent": { "$ref": "#/$defs/MeetingIntent" }
      }
    }
  }
}
