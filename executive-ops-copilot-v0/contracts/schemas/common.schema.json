{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.executive-ops-copilot/contracts/common.schema.json",
  "title": "CommonContracts",
  "description": "Shared API contracts used by OpenAPI and contract tests.",
  "$defs": {
    "ErrorResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["error"],
      "properties": {
        "error": {
          "type": "object",
          "additionalProperties": false,
          "required": ["code", "message"],
          "properties": {
            "code": {
              "type": "string",
              "enum": [
                "bad_request",
                "validation_error",
                "not_found",
                "conflict",
                "model_unavailable",
                "invalid_model_output",
                "persistence_error",
                "internal_error"
              ]
            },
            "message": {
              "type": "string",
              "minLength": 1
            },
            "field": {
              "type": "string"
            },
            "request_id": {
              "type": "string",
              "pattern": "^req_[A-Za-z0-9_-]+$"
            },
            "recommendation_id": {
              "type": "string",
              "pattern": "^rec_[A-Za-z0-9_-]+$"
            },
            "details": {
              "type": "object",
              "additionalProperties": true
            }
          }
        }
      }
    }
  },
  "$ref": "#/$defs/ErrorResponse",
  "examples": [
    {
      "error": {
        "code": "validation_error",
        "message": "raw_text is required.",
        "field": "raw_text"
      }
    }
  ]
}
