{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.executive-ops-copilot/contracts/recommendation.schema.json",
  "title": "Recommendation",
  "description": "Scheduling recommendation returned by the backend recommendation endpoint.",
  "$ref": "#/$defs/Recommendation",
  "$defs": {
    "Decision": { "type": "string", "enum": ["schedule", "decline", "clarify", "defer"] },
    "RiskLevel": { "type": "string", "enum": ["low", "medium", "high"] },
    "ModelStatus": { "type": "string", "enum": ["used", "unavailable", "invalid_output", "not_configured"] },
    "Risk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "message"],
      "properties": {
        "level": { "$ref": "#/$defs/RiskLevel" },
        "message": { "type": "string", "minLength": 1 }
      }
    },
    "ProposedSlot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start", "end", "reason"],
      "properties": {
        "start": { "type": "string", "format": "date-time" },
        "end": { "type": "string", "format": "date-time" },
        "reason": { "type": "string", "minLength": 1 }
      }
    },
    "Recommendation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision", "confidence", "rationale", "risks", "risk_level", "safe_action", "proposed_slots", "model_status"],
      "properties": {
        "decision": { "$ref": "#/$defs/Decision" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "rationale": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "risks": { "type": "array", "items": { "$ref": "#/$defs/Risk" } },
        "risk_level": { "$ref": "#/$defs/RiskLevel" },
        "safe_action": { "type": "string", "minLength": 1 },
        "proposed_slots": { "type": "array", "items": { "$ref": "#/$defs/ProposedSlot" } },
        "model_status": { "$ref": "#/$defs/ModelStatus" }
      }
    }
  }
}
