{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.executive-ops-copilot/contracts/recommendation.schema.json",
  "title": "Recommendation",
  "description": "Recommendation, decision feedback, and decision log contracts.",
  "$ref": "#/$defs/Recommendation",
  "$defs": {
    "RiskLevel": { "type": "string", "enum": ["none", "low", "medium", "high"] },
    "RecommendedAction": { "type": "string", "enum": ["accept", "decline", "propose_times", "ask_clarifying_question", "defer"] },
    "ModelStatus": { "type": "string", "enum": ["not_used", "used", "unavailable", "invalid_output"] },
    "RecommendationSlot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start", "end", "timezone", "reason"],
      "properties": {
        "start": { "type": "string", "format": "date-time" },
        "end": { "type": "string", "format": "date-time" },
        "timezone": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 },
        "calendar_conflicts": { "type": "array", "items": { "type": "string" } }
      }
    },
    "RiskItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["risk_level", "message"],
      "properties": {
        "risk_level": { "$ref": "#/$defs/RiskLevel" },
        "message": { "type": "string", "minLength": 1 },
        "related_rule_ids": { "type": "array", "items": { "type": "string" } }
      }
    },
    "Recommendation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["recommendation_id", "request_id", "recommended_action", "confidence", "risk_level", "human_review_required", "risks", "rationale", "proposed_slots", "model_status", "created_at"],
      "properties": {
        "recommendation_id": { "type": "string", "pattern": "^rec_[A-Za-z0-9_-]+$" },
        "request_id": { "type": "string", "pattern": "^req_[A-Za-z0-9_-]+$" },
        "recommended_action": { "$ref": "#/$defs/RecommendedAction" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "risk_level": { "$ref": "#/$defs/RiskLevel" },
        "human_review_required": { "type": "boolean" },
        "risks": { "type": "array", "items": { "$ref": "#/$defs/RiskItem" } },
        "rationale": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "proposed_slots": { "type": "array", "items": { "$ref": "#/$defs/RecommendationSlot" } },
        "applied_rule_ids": { "type": "array", "items": { "type": "string" } },
        "calendar_block_ids_considered": { "type": "array", "items": { "type": "string", "pattern": "^cal_[A-Za-z0-9_-]+$" } },
        "model_status": { "$ref": "#/$defs/ModelStatus" },
        "created_at": { "type": "string", "format": "date-time" }
      }
    },
    "DecisionFeedback": {
      "type": "object",
      "additionalProperties": false,
      "required": ["request_id", "recommendation_id", "final_action"],
      "properties": {
        "request_id": { "type": "string", "pattern": "^req_[A-Za-z0-9_-]+$" },
        "recommendation_id": { "type": "string", "pattern": "^rec_[A-Za-z0-9_-]+$" },
        "draft_id": { "type": "string", "pattern": "^draft_[A-Za-z0-9_-]+$" },
        "final_action": { "$ref": "#/$defs/RecommendedAction" },
        "accepted_recommendation": { "type": "boolean", "default": false },
        "draft_was_edited": { "type": "boolean", "default": false },
        "final_response_text": { "type": "string", "maxLength": 6000 },
        "selected_slot": { "$ref": "#/$defs/RecommendationSlot" },
        "user_notes": { "type": "string", "maxLength": 4000 },
        "actor_id": { "type": "string" }
      }
    },
    "DecisionLogEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision_id", "request_id", "recommendation_id", "recommended_action", "final_action", "accepted_recommendation", "created_at"],
      "properties": {
        "decision_id": { "type": "string", "pattern": "^dec_[A-Za-z0-9_-]+$" },
        "request_id": { "type": "string", "pattern": "^req_[A-Za-z0-9_-]+$" },
        "recommendation_id": { "type": "string", "pattern": "^rec_[A-Za-z0-9_-]+$" },
        "draft_id": { "type": "string", "pattern": "^draft_[A-Za-z0-9_-]+$" },
        "request_title": { "type": "string" },
        "requester_name": { "type": "string" },
        "recommended_action": { "$ref": "#/$defs/RecommendedAction" },
        "final_action": { "$ref": "#/$defs/RecommendedAction" },
        "accepted_recommendation": { "type": "boolean" },
        "draft_was_edited": { "type": "boolean" },
        "final_response_text": { "type": "string" },
        "selected_slot": { "$ref": "#/$defs/RecommendationSlot" },
        "user_notes": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "actor_id": { "type": "string" }
      }
    }
  }
}
