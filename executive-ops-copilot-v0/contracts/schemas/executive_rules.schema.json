{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.executive-ops-copilot/contracts/executive_rules.schema.json",
  "title": "ExecutiveRules",
  "description": "Single-executive scheduling rules returned by the backend rules endpoint.",
  "$ref": "#/$defs/ExecutiveRules",
  "$defs": {
    "WorkingHours": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start", "end"],
      "properties": {
        "start": { "type": "string", "pattern": "^([01]\\d|2[0-3]):[0-5]\\d$" },
        "end": { "type": "string", "pattern": "^([01]\\d|2[0-3]):[0-5]\\d$" }
      }
    },
    "ProtectedBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "start", "end"],
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "start": { "type": "string", "format": "date-time" },
        "end": { "type": "string", "format": "date-time" }
      }
    },
    "ExecutiveRules": {
      "type": "object",
      "additionalProperties": false,
      "required": ["executive_name", "timezone", "working_hours", "protected_blocks", "preferences"],
      "properties": {
        "executive_name": { "type": "string", "minLength": 1 },
        "timezone": { "type": "string", "minLength": 1 },
        "working_hours": { "$ref": "#/$defs/WorkingHours" },
        "protected_blocks": { "type": "array", "items": { "$ref": "#/$defs/ProtectedBlock" } },
        "preferences": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    }
  }
}
